# ─── Django Core ────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=your-generated-secret-key-here
DJANGO_SETTINGS_MODULE=shop.settings.production
ALLOWED_HOSTS=your-app-name.onrender.com,your-app-name-*.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-app-name.onrender.com,https://your-app-name-*.onrender.com

# ─── Database (Render sets this automatically) ───────────────────────────────
DATABASE_URL=postgresql://username:password@hostname:port/database

# ─── Site URL ────────────────────────────────────────────────────────────────
SITE_URL=https://your-app-name.onrender.com

# ─── Admin Account ───────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_PHONE=+380000000000

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# ─── Cloudinary (media storage) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Nova Post API ───────────────────────────────────────────────────────────
# Obtain your personal API key at https://new.novaposhta.ua/
NOVAPOST_API_KEY=your-novapost-api-key

# ─── Monobank Acquiring ──────────────────────────────────────────────────────
MONOBANK_TOKEN=your-monobank-token
MONOBANK_WEBHOOK_URL=https://your-app-name.onrender.com/orders/payment/webhook/

# ─── Optional ────────────────────────────────────────────────────────────────
# REDIS_URL=redis://...
# SENTRY_DSN=https://...
